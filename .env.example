# Oura OAuth2 app credentials — register at https://cloud.ouraring.com/oauth/applications
OURA_CLIENT_ID=your_oura_client_id
OURA_CLIENT_SECRET=your_oura_client_secret
# Must exactly match the redirect URI registered on your Oura OAuth app
OURA_REDIRECT_URI=http://localhost:8080/callback

# Claude Code Routine trigger endpoint (pre-existing, provided by you)
ROUTINE_TRIGGER_URL=https://your-routine-host/trigger/your-routine-id
ROUTINE_API_TOKEN=your_routine_bearer_token

# Optional — override the default OAuth scope list
# OURA_SCOPES=email personal daily heartrate workout tag session spo2 stress heart_health
